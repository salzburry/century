__pycache__/
*.pyc
*.pyo
.venv/
.DS_Store

# Local credentials — keep .env out of git. .env.example is the committed template.
.env

# Generated dictionary artifacts. Only the reference PDFs under Output/
# are committed; xlsx / html / json outputs are rebuilt on each run of
# build_dictionary.py and should not be version-controlled.
Output/**/*.xlsx
Output/**/*.html
Output/**/*.json

# Runtime bundle(s) produced by scripts/build_runtime_bundle.sh. These
# are regenerated from source on demand, so committing them just
# creates a stale snapshot (the old century-dictionary-runtime.zip went
# exactly that way before it was removed). Keep them out of git.
*.zip
