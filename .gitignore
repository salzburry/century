__pycache__/
*.pyc
*.pyo
.venv/
.DS_Store

# Local credentials — keep .env out of git. .env.example is the committed template.
.env

# Generated dictionary artifacts. Only the reference PDFs under Output/
# are committed; xlsx / html / json outputs are rebuilt on each run of
# build_dictionary.py and should not be version-controlled.
Output/**/*.xlsx
Output/**/*.html
Output/**/*.json

# Raw schema dumps produced by scripts/dump_new_schemas.py. These
# contain real warehouse concept-name distributions, row counts, and
# person counts — privacy-sensitive enough that they stay out of git.
# Mine them locally to inform pack curation, then delete.
Output/raw/

# VALIDATION_REPORT.md is generated by scripts/validate_packs.py on
# every run. The runtime zip bundles a fresh snapshot of it at build
# time, so the repo doesn't also need to track the committed copy.
VALIDATION_REPORT.md
